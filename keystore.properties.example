# Copy to `keystore.properties` (git-ignored) and fill in.
# storeFile is resolved relative to the project root.
#
# CI alternative — set these env vars instead of using a file:
#   PAPERCUT_STORE_FILE, PAPERCUT_STORE_PASSWORD,
#   PAPERCUT_KEY_ALIAS, PAPERCUT_KEY_PASSWORD

storeFile=papercut-upload.jks
storePassword=CHANGE_ME
keyAlias=papercut
keyPassword=CHANGE_ME
